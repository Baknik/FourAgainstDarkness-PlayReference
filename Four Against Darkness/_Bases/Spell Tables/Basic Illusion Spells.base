views:
  - type: list
    name: Table
    filters:
      and:
        - file.tags.containsAll("spell", "illusion")
        - file.tags.contains("basic")
    order:
      - file.name
      - file.tags
    sort:
      - property: formula.Untitled
        direction: ASC
    markers: number
    image: note.tags
    indentProperties: false
